@{
    Layout = "Layout.cshtml";
}

<div class="pt-16 pb-12 antialiased">
  <div class="flex flex-col md:flex-row gap-16">
    <div class="md:w-2/3">
      <div class="flex items-center gap-3 mb-4">
        <h1 class="text-3xl font-extrabold text-[#233038] tracking-tight">About Me</h1>
        <img src="/swytchserver/static/flag.svg" class="w-7 h-7" alt="Flag">
      </div>
      
      <div class="space-y-6 text-lg text-gray-800 leading-relaxed">
        <p>
          Hello, I’m Matthew Gwalisam. I'm a programmer based in Ghana. This site is my personal space to document my journey, share technical deep-dives, and showcase the tools I build.
        </p>
        
        <p>
          I am deeply fascinated by low-level systems and infrastructure. My interests include 
          <span class="font-bold text-[#075056]">operating systems</span>, 
          <span class="font-bold text-[#075056]">concurrency</span>, 
          <span class="font-bold text-[#075056]">networking</span>, and 
          <span class="font-bold text-[#075056]">programming language design</span>.
        </p>

        <p>
          I believe in understanding how things work from the ground up. Whether it's debugging a kernel module or architecting a distributed system, I enjoy the challenge of building robust, efficient software.
        </p>

        <p>
          Outside of the terminal, I'm an enthusiast of minimalist art and modern interior design. I find that the same principles of balance and clarity apply to both good code and good living spaces.
        </p>
      </div>

      <div class="mt-12 flex flex-wrap items-center gap-6">
        <a href="mailto:gwalisammatthew2@gmail.com" class="px-6 py-3 bg-[#075056] text-white font-bold rounded-xl hover:bg-[#053d42] transition-colors shadow-sm">
          Email Me
        </a>
        <div class="flex gap-5">
          <a href="https://github.com/Gwali-1" target="_blank" class="hover:scale-110 transition-transform duration-200">
            <img src="/swytchserver/static/github-mark.svg" class="w-6 h-6 opacity-80 hover:opacity-100" alt="GitHub">
          </a>
          <a href="https://twitter.com/Gwalisam1" target="_blank" class="hover:scale-110 transition-transform duration-200">
            <img src="/swytchserver/static/twitter.svg" class="w-6 h-6 opacity-80 hover:opacity-100" alt="Twitter">
          </a>
        </div>
      </div>
    </div>

    <div class="md:w-1/3 flex justify-center items-start">
      <div class="sticky top-8">
        <div class="w-64 h-64 rounded-2xl overflow-hidden border-2 border-gray-200 shadow-xl rotate-3 hover:rotate-0 transition-transform duration-500">
          <img src="/swytchserver/static/sideview.svg" class="w-full h-full object-cover" alt="Matthew Gwalisam">
        </div>
      </div>
    </div>
  </div>
</div>
