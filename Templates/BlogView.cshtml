
@model Site.Models.BlogPost
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>@Model.Title</title>
    <link href="/swytchserver/static/style.css" rel="stylesheet">
    <script src="/swytchserver/static/htmx.min.js"></script>

    <!-- Basic -->
    <meta name="description" content="@Model.Title">

    <!-- Open Graph -->
    <meta property="og:title" content="@Model.Title" />
    <meta property="og:description" content="@Model.Title" />
    <meta property="og:image" content="https://github.com/Gwali-1/Site/blob/2feaae4bb1517985a9987443eac2811769cb1080/Statics/sideview.jpg" />
    <meta property="og:url" content="https://yoursite.com/blog/my-post" />
    <meta property="og:type" content="article" />
    <meta property="og:site_name" content="Gwalisam Site" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="@Model.Title" />
    <meta name="twitter:description" content="@Model.Title" />
    <meta name="twitter:image" content="https://github.com/Gwali-1/Site/blob/2feaae4bb1517985a9987443eac2811769cb1080/Statics/sideview.jpg" />
    <!-- <script src="https://cdn.jsdelivr.net/npm/@@tailwindcss/browser@@4"></script> -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,100..900;1,100..900&family=Montserrat:ital,wght@0,100..900;1,100..900&family=Outfit:wght@100..900&display=swap" rel="stylesheet">

  </head>
  <body class="bg-[#D3DBDD] font-sans  text-gray-900 antialiased">
    <header class="container mx-auto max-w-4xl p-4">
      <nav id="main-nav" class="flex items-center gap-6 pt-8 text-lg font-nav font-semibold tracking-tight">
        <a href="/" hx-get="/" hx-target="#response-content" hx-trigger="click" hx-push-url="/" 
          hx-swap="innerHTML transition:true" class="text-gray-400! hover:text-[#075056]! transition-colors" >Home</a>
        <a href="/blog" hx-get="/blog" hx-target="#response-content" hx-trigger="click" hx-push-url="/blog" 
          hx-swap="innerHTML transition:true" class="text-[#075056]! hover:text-[#075056]! transition-colors">Blog</a>
        <a href="/projects" hx-get="/projects" hx-target="#response-content" hx-trigger="click" hx-push-url="/projects"
          hx-swap="innerHTML transition:true" class="text-gray-400! hover:text-[#075056]! transition-colors">Projects</a>
      </nav>
    </header>
    <div class="container mx-auto max-w-4xl p-4" id ="response-content"> 


<div class="mx-auto pt-10">  

  <!-- Title + Meta -->
  <header class="mb-8">
      <h1 class="text-4xl font-bold font-[noto] mb-2">@Model.Title</h1>
      <p class="text-sm font-semibold text-[#DB6B43]">
        @Model.Date
      </p>
  </header>

  <!-- Content -->
  <article class="prose prose-slate max-w-none font-semibold text-sm">
      @Raw(Model.Content)
  </article>
</div>

    <footer class="container mx-auto mb-1 max-w-4xl pt-12">

      <div class="bg-[#233038] p-6 text-white">
      &copy; <span id="year"></span> Matthew Gwalisam. All rights reserved.<br>
      <span class="text-sm">Built with Swytch X Tailwind CSS X HTMX </span><br>
     <span class = "text-sm hover:text-[#075056]">source code: <a href="https://github.com/Gwali-1/Site">https://github.com/Gwali-1/Site</a></span>
      </div>
    </footer>
    <script>
      document.getElementById("year").textContent = new Date().getFullYear();
    </script>

  </body>
</html>

