

@model Site.Models.BlogPost

<div class="mx-auto pt-10">  

  <!-- Title + Meta -->
  <header class="mb-8">
      <h1 class="text-4xl font-bold font-[noto] mb-2">@Model.Title</h1>
      <p class="text-sm font-semibold text-[#DB6B43]">
        @Model.Date
      </p>
  </header>

  <!-- Content -->
  <article class="prose prose-slate max-w-none font-semibold text-sm">
      @Raw(Model.Content)
  </article>
</div>
